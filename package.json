{
  "name": "mekasaapp",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/heebo": "^0.4.2",
    "@expo-google-fonts/karantina": "^0.4.1",
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.0",
    "expo": "~57.0.2",
    "expo-auth-session": "~57.0.1",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-location": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "maplibre-gl": "^5.24.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "opentype.js": "^2.0.0",
    "sharp": "^0.35.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit",
    "security-check": "node scripts/security-check.mjs",
    "prepare": "husky"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "clearMocks": true,
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|standard-navigation)"
    ],
    "collectCoverageFrom": [
      "src/store/**/*.ts",
      "!src/store/**/__tests__/**"
    ]
  }
}
